  "quotes": [
    { "id":  1, "text": "一阴一阳之谓道",                    "source": "易传·系辞上",       "tag": "flow",   "confidence": "high" },
    { "id":  2, "text": "时止则止,时行则行",                "source": "易经·艮卦",         "tag": "wait",   "confidence": "high" },
    { "id":  3, "text": "君子藏器于身,待时而动",            "source": "易传·系辞下",       "tag": "wait",   "confidence": "high" },
    { "id":  4, "text": "穷则变,变则通,通则久",           "source": "易传·系辞下",       "tag": "change", "confidence": "high" },
    { "id":  5, "text": "飞龙在天,利见大人",                "source": "易经·乾卦九五",     "tag": "act",    "confidence": "high" },
    { "id":  6, "text": "亢龙有悔",                          "source": "易经·乾卦上九",     "tag": "still",  "confidence": "high" },
    { "id":  7, "text": "同声相应,同气相求",                "source": "易传·乾卦文言",     "tag": "flow",   "confidence": "high" },
    { "id":  8, "text": "二人同心,其利断金",                "source": "易传·系辞上",       "tag": "act",    "confidence": "high" },
    { "id":  9, "text": "天行健,君子以自强不息",            "source": "易经·乾·象传",      "tag": "act",    "confidence": "high" },
    { "id": 10, "text": "地势坤,君子以厚德载物",            "source": "易经·坤·象传",      "tag": "still",  "confidence": "high" },
    { "id": 11, "text": "履霜,坚冰至",                      "source": "易经·坤卦初六",     "tag": "wait",   "confidence": "high" },
    { "id": 12, "text": "谦谦君子,卑以自牧",                "source": "易经·谦卦初六",     "tag": "self",   "confidence": "high" },
    { "id": 13, "text": "君子终日乾乾,夕惕若",              "source": "易经·乾卦九三",     "tag": "self",   "confidence": "high" },
    { "id": 14, "text": "见龙在田,德施普也",                "source": "易经·乾卦九二",     "tag": "act",    "confidence": "high" },
    { "id": 15, "text": "君子以独立不惧,遁世无闷",          "source": "易经·大过·象传",    "tag": "self",   "confidence": "high" },
    { "id": 16, "text": "君子以慎言语,节饮食",              "source": "易经·颐·象传",      "tag": "self",   "confidence": "high" },
    { "id": 17, "text": "君子以果行育德",                    "source": "易经·蒙·象传",      "tag": "self",   "confidence": "high" },
    { "id": 18, "text": "君子以见善则迁,有过则改",          "source": "易经·益·象传",      "tag": "change", "confidence": "high" },
    { "id": 19, "text": "君子以非礼弗履",                    "source": "易经·大壮·象传",    "tag": "still",  "confidence": "high" },
    { "id": 20, "text": "鸣谦,贞吉",                        "source": "易经·谦卦上六",     "tag": "self",   "confidence": "high" },

    { "id": 21, "text": "上善若水",                          "source": "道德经·八章",       "tag": "flow",   "confidence": "high" },
    { "id": 22, "text": "夫唯不争,故天下莫能与之争",        "source": "道德经·二十二章",   "tag": "still",  "confidence": "high" },
    { "id": 23, "text": "将欲取之,必固与之",                "source": "道德经·三十六章",   "tag": "wait",   "confidence": "high" },
    { "id": 24, "text": "大器晚成,大音希声",                "source": "道德经·四十一章",   "tag": "wait",   "confidence": "high" },
    { "id": 25, "text": "祸兮福所倚,福兮祸所伏",            "source": "道德经·五十八章",   "tag": "change", "confidence": "high" },
    { "id": 26, "text": "天之道,损有余而补不足",            "source": "道德经·七十七章",   "tag": "flow",   "confidence": "high" },
    { "id": 27, "text": "不行而知,不见而明",                "source": "道德经·四十七章",   "tag": "still",  "confidence": "high" },
    { "id": 28, "text": "道可道,非常道",                    "source": "道德经·一章",       "tag": "still",  "confidence": "high" },
    { "id": 29, "text": "知人者智,自知者明",                "source": "道德经·三十三章",   "tag": "self",   "confidence": "high" },
    { "id": 30, "text": "胜人者有力,自胜者强",              "source": "道德经·三十三章",   "tag": "self",   "confidence": "high" },
    { "id": 31, "text": "知足者富,强行者有志",              "source": "道德经·三十三章",   "tag": "self",   "confidence": "high" },
    { "id": 32, "text": "致虚极,守静笃",                    "source": "道德经·十六章",     "tag": "still",  "confidence": "high" },
    { "id": 33, "text": "万物并作,吾以观复",                "source": "道德经·十六章",     "tag": "still",  "confidence": "high" },
    { "id": 34, "text": "善行无辙迹,善言无瑕谪",            "source": "道德经·二十七章",   "tag": "act",    "confidence": "high" },
    { "id": 35, "text": "天下莫柔弱于水,而攻坚强者莫之能胜","source": "道德经·七十八章",   "tag": "flow",   "confidence": "high" },
    { "id": 36, "text": "反者道之动,弱者道之用",            "source": "道德经·四十章",     "tag": "change", "confidence": "high" },
    { "id": 37, "text": "天网恢恢,疏而不失",                "source": "道德经·七十三章",   "tag": "wait",   "confidence": "high" },
    { "id": 38, "text": "为学日益,为道日损",                "source": "道德经·四十八章",   "tag": "self",   "confidence": "high" },
    { "id": 39, "text": "曲则全,枉则直",                    "source": "道德经·二十二章",   "tag": "flow",   "confidence": "high" },
    { "id": 40, "text": "重为轻根,静为躁君",                "source": "道德经·二十六章",   "tag": "still",  "confidence": "high" },

    { "id": 41, "text": "至人之用心若镜,不将不迎",          "source": "庄子·应帝王",       "tag": "still",  "confidence": "high" },
    { "id": 42, "text": "无用之用,方为大用",                "source": "庄子·人间世",       "tag": "self",   "confidence": "high" },
    { "id": 43, "text": "朝菌不知晦朔,蟪蛄不知春秋",        "source": "庄子·逍遥游",       "tag": "wait",   "confidence": "high" },
    { "id": 44, "text": "吾生也有涯,而知也无涯",            "source": "庄子·养生主",       "tag": "self",   "confidence": "high" },
    { "id": 45, "text": "君子之交淡若水",                    "source": "庄子·山木",         "tag": "flow",   "confidence": "high" },
    { "id": 46, "text": "天地与我并生,万物与我为一",        "source": "庄子·齐物论",       "tag": "flow",   "confidence": "high" },
    { "id": 47, "text": "大知闲闲,小知间间",                "source": "庄子·齐物论",       "tag": "self",   "confidence": "high" },
    { "id": 48, "text": "其嗜欲深者,其天机浅",              "source": "庄子·大宗师",       "tag": "self",   "confidence": "high" },
    { "id": 49, "text": "夫物芸芸,各复归其根",              "source": "道德经·十六章",     "tag": "still",  "confidence": "high" },
    { "id": 50, "text": "圣人不积,既以为人己愈有",          "source": "道德经·八十一章",   "tag": "flow",   "confidence": "high" },

    { "id": 51, "text": "人无远虑,必有近忧",                "source": "论语·卫灵公",       "tag": "wait",   "confidence": "high" },
    { "id": 52, "text": "君子求诸己,小人求诸人",            "source": "论语·卫灵公",       "tag": "self",   "confidence": "high" },
    { "id": 53, "text": "知之为知之,不知为不知",            "source": "论语·为政",         "tag": "self",   "confidence": "high" },
    { "id": 54, "text": "三人行,必有我师",                  "source": "论语·述而",         "tag": "self",   "confidence": "high" },
    { "id": 55, "text": "任重而道远,死而后已",              "source": "论语·泰伯",         "tag": "act",    "confidence": "high" },
    { "id": 56, "text": "不患人之不己知,患不知人也",        "source": "论语·学而",         "tag": "self",   "confidence": "high" },
    { "id": 57, "text": "克己复礼为仁",                      "source": "论语·颜渊",         "tag": "self",   "confidence": "high" },
    { "id": 58, "text": "凡事豫则立,不豫则废",              "source": "礼记·中庸",         "tag": "act",    "confidence": "high" },
    { "id": 59, "text": "致广大而尽精微",                    "source": "礼记·中庸",         "tag": "self",   "confidence": "high" },
    { "id": 60, "text": "无入而不自得",                      "source": "礼记·中庸",         "tag": "still",  "confidence": "high" },

    { "id": 61, "text": "无心恰恰用,常用恰恰无心",          "source": "永嘉证道歌",        "tag": "still",  "confidence": "high" },
    { "id": 62, "text": "菩提本无树,明镜亦非台",            "source": "六祖坛经",          "tag": "still",  "confidence": "high" },
    { "id": 63, "text": "应无所住而生其心",                  "source": "金刚经",            "tag": "flow",   "confidence": "high" },
    { "id": 64, "text": "一切有为法,如梦幻泡影",            "source": "金刚经",            "tag": "change", "confidence": "high" },
    { "id": 65, "text": "春有百花秋有月,夏有凉风冬有雪",    "source": "无门慧开·禅诗",     "tag": "flow",   "confidence": "high" },
    { "id": 66, "text": "不思善,不思恶",                    "source": "六祖坛经",          "tag": "still",  "confidence": "high" },
    { "id": 67, "text": "见性是功,平等是德",                "source": "六祖坛经",          "tag": "self",   "confidence": "high" },
    { "id": 68, "text": "烦恼即菩提",                        "source": "禅宗",              "tag": "change", "confidence": "high" },
    { "id": 69, "text": "云在青天水在瓶",                    "source": "李翱·赠药山禅师",   "tag": "still",  "confidence": "high" },
    { "id": 70, "text": "饥来吃饭困来眠",                    "source": "禅宗·王梵志体",     "tag": "still",  "confidence": "med"  },

    { "id": 71, "text": "知行合一",                          "source": "王阳明·传习录",     "tag": "act",    "confidence": "high" },
    { "id": 72, "text": "心外无物",                          "source": "王阳明·传习录",     "tag": "self",   "confidence": "high" },
    { "id": 73, "text": "此心光明,亦复何言",                "source": "王阳明·临终遗言",   "tag": "self",   "confidence": "high" },
    { "id": 74, "text": "圣人之道,吾性自足",                "source": "王阳明·龙场悟道",   "tag": "self",   "confidence": "high" },
    { "id": 75, "text": "破山中贼易,破心中贼难",            "source": "王阳明·与杨仕德书", "tag": "self",   "confidence": "high" },
    { "id": 76, "text": "心即理也",                          "source": "王阳明·传习录",     "tag": "self",   "confidence": "high" },
    { "id": 77, "text": "持志如心痛",                        "source": "王阳明·传习录",     "tag": "self",   "confidence": "high" },
    { "id": 78, "text": "省察是有事时存养",                  "source": "王阳明·传习录",     "tag": "self",   "confidence": "high" },

    { "id": 79, "text": "既往不恋,当下不杂,未来不迎",      "source": "曾国藩·家书",       "tag": "still",  "confidence": "med"  },
    { "id": 80, "text": "物来顺应,事过心宁",                "source": "曾国藩·治心经",     "tag": "flow",   "confidence": "med"  },
    { "id": 81, "text": "慎独则心安",                        "source": "曾国藩·家书",       "tag": "self",   "confidence": "high" },

    { "id": 82, "text": "行到水穷处,坐看云起时",            "source": "王维·终南别业",     "tag": "wait",   "confidence": "high" },
    { "id": 83, "text": "山重水复疑无路,柳暗花明又一村",    "source": "陆游·游山西村",     "tag": "change", "confidence": "high" },
    { "id": 84, "text": "不识庐山真面目,只缘身在此山中",    "source": "苏轼·题西林壁",     "tag": "self",   "confidence": "high" },
    { "id": 85, "text": "莫听穿林打叶声,何妨吟啸且徐行",    "source": "苏轼·定风波",       "tag": "still",  "confidence": "high" },
    { "id": 86, "text": "回首向来萧瑟处,也无风雨也无晴",    "source": "苏轼·定风波",       "tag": "still",  "confidence": "high" },
    { "id": 87, "text": "时来天地皆同力,运去英雄不自由",    "source": "罗隐·筹笔驿",       "tag": "wait",   "confidence": "high" },
    { "id": 88, "text": "竹杖芒鞋轻胜马,谁怕",              "source": "苏轼·定风波",       "tag": "act",    "confidence": "high" },
    { "id": 89, "text": "万古长空,一朝风月",                "source": "崇慧禅师",          "tag": "still",  "confidence": "high" },
    { "id": 90, "text": "千江有水千江月,万里无云万里天",    "source": "雷庵正受·嘉泰普灯录","tag": "flow",   "confidence": "high" }
  ]
}
